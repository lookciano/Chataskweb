# Database Configuration (TiDB Cloud / MySQL)
# Use the full mysql:// URL including SSL-capable host. App enables SSL automatically.
DATABASE_URL=mysql://user:password@gateway.tidbcloud.com:4000/dbname

# OpenRouter LLM Configuration
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=deepseek/deepseek-chat

# Authentication (required in production — used to sign local session cookies)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Optional: password required to create/delete chat rooms
ROOM_ADMIN_PASSWORD=12345

# Application
APP_URL=https://chataskweb.onrender.com
NODE_ENV=production
PORT=3000
